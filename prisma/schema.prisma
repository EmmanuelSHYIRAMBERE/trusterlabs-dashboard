datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "admin" | "user"
  password      String?
  department    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  blogPosts BlogPost[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ────────────────────────────────────────────────────────────

model BlogPost {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  category      String    @default("Cybersecurity Capacity Building")
  imageUrl      String?
  tags          String[]
  featured      Boolean   @default(false)
  readTime      Int       @default(5)
  status        String    @default("Draft") // "Draft" | "Scheduled" | "Published"
  publishedDate DateTime?
  createdDate   DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  views         Int       @default(0)
  engagement    Int       @default(0)

  authorId String @db.ObjectId
  author   User   @relation(fields: [authorId], references: [id])
}

model InternshipApplication {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  position    String
  status      String   @default("New Application")
  // "New Application" | "Under Review" | "Interview Scheduled" | "Offer Extended" | "Rejected"
  rating      Float    @default(0)
  appliedDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingProgram {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  enrolled    Int      @default(0)
  completed   Int      @default(0)
  deadline    DateTime
  status      String   @default("Active") // "Active" | "Upcoming" | "Inactive"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Incident {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  severity  String   @default("Medium") // "Critical" | "High" | "Medium" | "Low"
  status    String   @default("Under Review")
  // "Under Review" | "Investigating" | "Monitoring" | "Resolved"
  platform  String
  timestamp DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
